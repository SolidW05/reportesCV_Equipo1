---
export interface Props {
  reportId: number | string;
  alt?: string;
  class?: string;
}
const { reportId, alt = 'Imagen del reporte', class: className = '' } = Astro.props;
const src = `/api/report/images/${reportId}`;
---

<figure class={`report-img-wrap ${className}`}>
  <img
    src={src}
    alt={alt}
    class="report-img"
    loading="lazy"
    onerror="this.parentElement.classList.add('img-fallback'); this.style.display='none'; this.parentElement.querySelector('.img-placeholder').style.display='flex';"
  />
  <div class="img-placeholder" style="display:none">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
    </svg>
    <span>Sin imagen</span>
  </div>
</figure>

<style>
.report-img-wrap {
  border-radius: var(--radius-lg); overflow: hidden;
  background: var(--surface-2); border: 1px solid var(--border);
  aspect-ratio: 16/9; display: block; position: relative;
}
.report-img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.3s ease;
}
.report-img-wrap:hover .report-img { transform: scale(1.02); }
.img-placeholder {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 0.5rem; color: var(--text-muted); font-size: 0.8rem; font-family: var(--font-mono);
}
</style>
