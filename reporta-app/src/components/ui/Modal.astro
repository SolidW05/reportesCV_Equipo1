---
export interface Props {
  id: string;
  title?: string;
  confirmText?: string;
  cancelText?: string;
  variant?: 'default' | 'danger';
}
const {
  id, title = 'Confirmar', confirmText = 'Confirmar',
  cancelText = 'Cancelar', variant = 'default',
} = Astro.props;
---

<dialog id={id} class="modal" aria-labelledby={`${id}-title`}>
  <div class="modal-inner">
    <div class="modal-header">
      <h3 id={`${id}-title`} class="modal-title">{title}</h3>
      <button class="modal-close" data-modal-close={id} aria-label="Cerrar">✕</button>
    </div>
    <div class="modal-body">
      <slot />
    </div>
    {(confirmText || cancelText) && (
      <div class="modal-footer">
        {cancelText && (
          <button class="modal-btn modal-cancel" data-modal-close={id}>{cancelText}</button>
        )}
        {confirmText && (
          <button class={`modal-btn modal-confirm ${variant === 'danger' ? 'modal-danger' : ''}`} data-modal-confirm={id}>
            {confirmText}
          </button>
        )}
      </div>
    )}
  </div>
</dialog>

<style>
.modal {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-lg); color: var(--text);
  padding: 0; max-width: min(480px, 90vw);
  box-shadow: var(--shadow); outline: none;
  animation: fadeSlideUp 0.2s ease;
}
.modal::backdrop {
  background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
}
.modal-inner { padding: 1.5rem; }
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1rem;
}
.modal-title { font-size: 1.1rem; }
.modal-close {
  background: none; border: none; color: var(--text-muted);
  cursor: pointer; font-size: 1rem; transition: color var(--transition);
  line-height: 1; padding: 0.2rem 0.4rem; border-radius: 4px;
}
.modal-close:hover { color: var(--text); background: var(--surface-2); }
.modal-body { margin-bottom: 1.5rem; color: var(--text-dim); line-height: 1.6; }
.modal-footer { display: flex; gap: 0.75rem; justify-content: flex-end; }
.modal-btn {
  font-family: var(--font-display); font-weight: 700; font-size: 0.875rem;
  padding: 0.55rem 1.1rem; border-radius: var(--radius); cursor: pointer;
  transition: all var(--transition); border: none;
}
.modal-cancel {
  background: var(--surface-2); color: var(--text-dim);
  border: 1px solid var(--border);
}
.modal-cancel:hover { color: var(--text); }
.modal-confirm {
  background: var(--accent); color: var(--bg);
}
.modal-confirm:hover { background: var(--accent-hover); }
.modal-danger {
  background: var(--danger); color: #fff;
}
.modal-danger:hover { opacity: 0.9; }
</style>

<script>
  // Generic modal open/close helpers (exposed globally)
  function openModal(modalId: string) {
    const modal = document.getElementById(modalId) as HTMLDialogElement | null;
    modal?.showModal();
  }
  function closeModal(modalId: string) {
    const modal = document.getElementById(modalId) as HTMLDialogElement | null;
    modal?.close();
  }

  document.querySelectorAll('[data-modal-close]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.modalClose!;
      closeModal(id);
    });
  });

  // Close on backdrop click
  document.querySelectorAll<HTMLDialogElement>('.modal').forEach(modal => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  });

  // Export globally so other scripts can use
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
</script>
