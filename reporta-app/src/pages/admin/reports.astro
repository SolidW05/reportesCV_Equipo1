---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';
import ReportStatusForm from '../../components/reports/ReportStatusForm.astro';
import type { ReportResponseDto } from '../../types/report';

// Get municipio filter from query param
const urlParams = new URL(Astro.request.url);
const municipioFilter = urlParams.searchParams.get('municipio') ?? '';

let reports: ReportResponseDto[] = [];
let error: string | null = null;

try {
  const endpoint = municipioFilter
    ? `http://localhost:8083/api/report/municipio/${encodeURIComponent(municipioFilter)}`
    : `http://localhost:8083/api/report/usuarios/1`; // fallback
  const res = await fetch(endpoint);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  reports = await res.json();
} catch (e) {
  error = (e as Error).message;
}
---

<DashboardLayout title="Admin — Reportes" section="Gestión de Reportes">

  <!-- Search Bar -->
  <div class="admin-toolbar">
    <form method="get" class="search-form">
      <label for="municipio" class="search-label mono">Filtrar por Municipio</label>
      <div class="search-row">
        <input
          id="municipio"
          name="municipio"
          type="text"
          placeholder="Ej: Tonalá"
          value={municipioFilter}
          class="search-input"
        />
        <button type="submit" class="search-btn">Buscar</button>
        {municipioFilter && (
          <a href="/admin/reports" class="clear-btn">✕ Limpiar</a>
        )}
      </div>
    </form>
    <div class="toolbar-meta mono">
      {reports.length} reporte{reports.length !== 1 ? 's' : ''}
      {municipioFilter && ` · "${municipioFilter}"`}
    </div>
  </div>

  <!-- Error -->
  {error && (
    <div class="alert-error">
      <strong>Error:</strong> {error}
      <p class="mono" style="font-size:0.75rem; margin-top:0.2rem; opacity:0.7">Backend: localhost:8083</p>
    </div>
  )}

  <!-- Table -->
  {!error && reports.length > 0 && (
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Descripción</th>
            <th>Estado</th>
            <th>Fecha</th>
            <th>Ubicación</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {reports.map((r) => (
            <tr class="admin-row" data-id={r.idReport}>
              <td class="mono td-id">#{r.idReport}</td>
              <td class="td-desc">
                <a href={`/reports/${r.idReport}`} class="report-link">{r.description}</a>
                {r.observaciones && (
                  <p class="obs-preview">{r.observaciones}</p>
                )}
              </td>
              <td><StatusBadge status={r.status} /></td>
              <td class="mono td-date">{new Date(r.date).toLocaleDateString('es-MX')}</td>
              <td class="mono td-loc">#{r.idLocation}</td>
              <td class="td-actions">
                <div class="action-row">
                  <button
                    class="action-btn btn-expand"
                    data-target={`sf-${r.idReport}`}
                    aria-expanded="false"
                  >
                    ✎ Estado
                  </button>
                  <button
                    class="action-btn btn-del"
                    data-del-id={r.idReport}
                  >
                    🗑 Eliminar
                  </button>
                </div>
                <!-- Inline Status Form (hidden by default) -->
                <div id={`sf-${r.idReport}`} class="sf-collapse" style="display:none">
                  <ReportStatusForm
                    reportId={r.idReport}
                    currentStatus={r.status}
                    currentObs={r.observaciones}
                  />
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {!error && reports.length === 0 && (
    <div class="empty-admin">
      <p>No se encontraron reportes{municipioFilter ? ` para "${municipioFilter}"` : ''}.</p>
      {municipioFilter && <a href="/admin/reports" class="clear-link">Ver todos los reportes</a>}
    </div>
  )}

  <!-- Delete Confirm Modal -->
  <dialog id="deleteModal" class="modal">
    <div class="modal-inner">
      <div class="modal-header">
        <h3 class="modal-title">Eliminar Reporte</h3>
        <button class="modal-close" id="closeDeleteModal">✕</button>
      </div>
      <div class="modal-body">
        ¿Estás seguro de que deseas eliminar el reporte <strong id="deleteReportId"></strong>?
        Esta acción no se puede deshacer.
      </div>
      <div class="modal-footer">
        <button class="modal-btn modal-cancel" id="cancelDelete">Cancelar</button>
        <button class="modal-btn modal-confirm modal-danger" id="confirmDelete">Eliminar</button>
      </div>
    </div>
  </dialog>

</DashboardLayout>

<style>
/* Toolbar */
.admin-toolbar {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;
}
.search-form { display: flex; flex-direction: column; gap: 0.4rem; }
.search-label {
  font-size: 0.7rem; color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 0.08em;
}
.search-row { display: flex; gap: 0.5rem; align-items: center; }
.search-input {
  background: var(--surface-2); border: 1px solid var(--border);
  color: var(--text); border-radius: var(--radius);
  padding: 0.55rem 0.875rem; font-family: var(--font-display); font-size: 0.875rem;
  width: 220px; outline: none; transition: border-color var(--transition);
}
.search-input:focus { border-color: var(--accent); }
.search-btn {
  background: var(--accent); color: var(--bg);
  font-family: var(--font-display); font-weight: 700; font-size: 0.8rem;
  padding: 0.55rem 1rem; border: none; border-radius: var(--radius);
  cursor: pointer; transition: all var(--transition);
}
.search-btn:hover { background: var(--accent-hover); }
.clear-btn {
  font-size: 0.78rem; color: var(--text-muted); text-decoration: none;
  transition: color var(--transition);
}
.clear-btn:hover { color: var(--danger); }
.toolbar-meta { font-size: 0.75rem; color: var(--text-muted); }

/* Alert */
.alert-error {
  background: var(--danger-dim); border: 1px solid rgba(239,68,68,0.3);
  border-radius: var(--radius-lg); padding: 1rem 1.25rem;
  color: var(--danger); margin-bottom: 1.5rem;
}

/* Table */
.table-wrap { overflow-x: auto; border-radius: var(--radius-lg); border: 1px solid var(--border); }
.admin-table {
  width: 100%; border-collapse: collapse; background: var(--surface);
}
.admin-table th {
  font-family: var(--font-mono); font-size: 0.68rem; font-weight: 600;
  color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;
  padding: 0.75rem 1rem; text-align: left;
  border-bottom: 1px solid var(--border); background: var(--surface-2);
  white-space: nowrap;
}
.admin-table td {
  padding: 0.875rem 1rem; border-bottom: 1px solid var(--border);
  vertical-align: top;
}
.admin-row:last-child td { border-bottom: none; }
.admin-row:hover td { background: rgba(245,158,11,0.03); }
.admin-row { transition: background var(--transition); }

.td-id { color: var(--text-muted); font-size: 0.8rem; white-space: nowrap; }
.td-date { font-size: 0.78rem; color: var(--text-muted); white-space: nowrap; }
.td-loc  { font-size: 0.78rem; color: var(--text-muted); }
.td-desc { max-width: 280px; }
.report-link {
  font-weight: 600; color: var(--text); font-size: 0.875rem;
  text-decoration: none; transition: color var(--transition);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.report-link:hover { color: var(--accent); }
.obs-preview {
  font-size: 0.75rem; color: var(--text-muted); margin-top: 0.3rem;
  font-style: italic;
}

/* Actions */
.td-actions { min-width: 200px; }
.action-row { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.action-btn {
  font-family: var(--font-display); font-weight: 700; font-size: 0.72rem;
  padding: 0.3rem 0.65rem; border-radius: var(--radius); cursor: pointer;
  border: none; transition: all var(--transition); white-space: nowrap;
}
.btn-expand {
  background: var(--info-dim); color: var(--info);
  border: 1px solid rgba(59,130,246,0.3);
}
.btn-expand:hover, .btn-expand[aria-expanded="true"] {
  background: var(--info); color: #fff;
}
.btn-del {
  background: var(--danger-dim); color: var(--danger);
  border: 1px solid rgba(239,68,68,0.3);
}
.btn-del:hover { background: var(--danger); color: #fff; }

.sf-collapse { margin-top: 0.75rem; }

/* Empty */
.empty-admin {
  text-align: center; padding: 3rem 2rem;
  background: var(--surface); border: 1px dashed var(--border);
  border-radius: var(--radius-lg); color: var(--text-muted);
}
.clear-link {
  display: block; margin-top: 0.75rem; color: var(--accent); font-weight: 600;
}

/* Modal overrides */
.modal {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-lg); color: var(--text);
  padding: 0; max-width: min(440px, 90vw); box-shadow: var(--shadow);
  outline: none;
}
.modal::backdrop { background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); }
.modal-inner { padding: 1.5rem; }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
.modal-title { font-size: 1.1rem; }
.modal-close {
  background: none; border: none; color: var(--text-muted); cursor: pointer;
  font-size: 1rem; padding: 0.2rem 0.4rem; border-radius: 4px;
  transition: all var(--transition);
}
.modal-close:hover { background: var(--surface-2); color: var(--text); }
.modal-body { color: var(--text-dim); line-height: 1.6; margin-bottom: 1.5rem; }
.modal-footer { display: flex; gap: 0.75rem; justify-content: flex-end; }
.modal-btn {
  font-family: var(--font-display); font-weight: 700; font-size: 0.875rem;
  padding: 0.55rem 1.1rem; border-radius: var(--radius); cursor: pointer; border: none;
  transition: all var(--transition);
}
.modal-cancel {
  background: var(--surface-2); color: var(--text-dim); border: 1px solid var(--border);
}
.modal-danger { background: var(--danger); color: #fff; }
.modal-danger:hover { opacity: 0.9; }
</style>

<script>
// Toggle status form rows
document.querySelectorAll<HTMLButtonElement>('.btn-expand').forEach(btn => {
  btn.addEventListener('click', () => {
    const targetId = btn.dataset.target!;
    const panel = document.getElementById(targetId);
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    if (panel) panel.style.display = isOpen ? 'none' : 'block';
  });
});

// Delete flow
const deleteModal = document.getElementById('deleteModal') as HTMLDialogElement;
const deleteIdEl  = document.getElementById('deleteReportId')!;
const confirmBtn  = document.getElementById('confirmDelete')!;
const cancelBtn   = document.getElementById('cancelDelete')!;
const closeBtn    = document.getElementById('closeDeleteModal')!;

let pendingDeleteId: number | null = null;

document.querySelectorAll<HTMLButtonElement>('.btn-del').forEach(btn => {
  btn.addEventListener('click', () => {
    pendingDeleteId = Number(btn.dataset.delId);
    deleteIdEl.textContent = `#${pendingDeleteId}`;
    deleteModal.showModal();
  });
});

[cancelBtn, closeBtn].forEach(b => b.addEventListener('click', () => {
  deleteModal.close(); pendingDeleteId = null;
}));
deleteModal.addEventListener('click', (e) => { if (e.target === deleteModal) deleteModal.close(); });

confirmBtn.addEventListener('click', async () => {
  if (!pendingDeleteId) return;
  confirmBtn.textContent = 'Eliminando...';
  confirmBtn.setAttribute('disabled', 'true');
  try {
    const res = await fetch(`/api/report/${pendingDeleteId}`, { method: 'DELETE' });
    if (!res.ok) throw new Error(`Error ${res.status}`);
    deleteModal.close();
    // Remove the row from the DOM
    const row = document.querySelector<HTMLTableRowElement>(`tr[data-id="${pendingDeleteId}"]`);
    row?.remove();
    pendingDeleteId = null;
  } catch (err) {
    alert(`Error al eliminar: ${(err as Error).message}`);
  } finally {
    confirmBtn.textContent = 'Eliminar';
    confirmBtn.removeAttribute('disabled');
  }
});
</script>
