---
import MainLayout from '../../layouts/MainLayout.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';
import ReportImage from '../../components/reports/ReportImage.astro';
import type { ReportResponseDto, LocationDto } from '../../types/report';
import { decodeJwt, isTokenExpired, JWT_COOKIE, ROLE_COOKIE, isAutoridad } from '../../utils/auth';
import { apiFetch2 } from "../../services/api";


// ── Auth guard: any authenticated role ──
const token = Astro.cookies.get(JWT_COOKIE)?.value;
if (!token) return Astro.redirect('/login');
const payload = decodeJwt(token);
if (!payload || isTokenExpired(payload)) return Astro.redirect('/login');

const { id } = Astro.params;

let report: ReportResponseDto | null = null;
let location: LocationDto | null = null;
let error: string | null = null;

try {
  const res = await apiFetch2(`/report/${id}`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  report = await res.json();
} catch (e) {
  error = (e as Error).message;
}

// Fetch location details for map popup
if (report?.idLocation) {
  try {
    const locRes = await apiFetch2(`/ubicacion/id/${report.idLocation}`, {
      headers: { Authorization: `Bearer ${token}` },
    });
    if (locRes.ok) location = await locRes.json();
  } catch {}
}

const dateFormatted = report
  ? new Date(report.date).toLocaleDateString('es-MX', {
      year: 'numeric', month: 'long', day: 'numeric'
    })
  : null;

const backUrl = isAutoridad(payload?.tipoUser) ? '/admin/reports' : '/reports';
---

<MainLayout title={report ? `Reporte #${report.idReport}` : 'Reporte'}>

  <!-- Leaflet (only if we have coordinates) -->
  {location && (
    <Fragment slot="head">
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
      <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    </Fragment>
  )}

  <div class="container section">

    <div class="page-breadcrumb">
      <a href={backUrl}>← {payload.role === 'autoridad' ? 'Panel Admin' : 'Mis Reportes'}</a>
    </div>

    {error && (
      <div class="alert-error">
        <strong>Reporte no encontrado:</strong> {error}
      </div>
    )}

    {report && (
      <div class="detail-wrap">
        <!-- Header -->
        <div class="detail-header animate-fade-up">
          <div class="detail-meta-top">
            <span class="detail-id mono">#{report.idReport}</span>
            <StatusBadge status={report.status} />
          </div>
          <h1 class="detail-title">{report.description}</h1>
          <div class="detail-meta-row">
            <span class="meta-item mono">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {dateFormatted}
            </span>
            <span class="meta-item mono">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {location ? location.municipio : `Ubicación #${report.idLocation}`}
            </span>
            {location && (
              <button class="btn-map" id="openMapBtn">
                🗺️ Ver en mapa
              </button>
            )}
          </div>
        </div>

        <div class="detail-body">
          <!-- Image -->
          <div class="detail-image-col animate-fade-up" style="animation-delay:80ms">
            <ReportImage reportId={report.idReport} />
          </div>

          <!-- Info -->
          <div class="detail-info-col animate-fade-up" style="animation-delay:160ms">

            <div class="info-card">
              <div class="info-card-label mono">Estado actual</div>
              <div class="status-row">
                <StatusBadge status={report.status} />
              </div>
            </div>

            {report.observaciones && (
              <div class="info-card obs-card">
                <div class="info-card-label mono">Observaciones del administrador</div>
                <blockquote class="obs-text">{report.observaciones}</blockquote>
              </div>
            )}

            <div class="info-card info-data">
              <div class="info-card-label mono">Datos del reporte</div>
              <dl class="data-list">
                <div class="data-row">
                  <dt>ID Reporte</dt><dd class="mono">#{report.idReport}</dd>
                </div>
                <div class="data-row">
                  <dt>Dirección</dt>
                  <dd class="mono">{location ? location.direccionCompleta : `#${report.idLocation}`}</dd>
                </div>
                {location && (
                  <div class="data-row">
                    <dt>Municipio</dt><dd class="mono">{location.municipio}</dd>
                  </div>
                )}
                <div class="data-row">
                  <dt>Fecha</dt><dd class="mono">{report.date}</dd>
                </div>
                {report.imageName && (
                  <div class="data-row">
                    <dt>Imagen</dt><dd class="mono">{report.imageName}</dd>
                  </div>
                )}
              </dl>
            </div>

            <a href={backUrl} class="btn-back">← Volver</a>
          </div>
        </div>
      </div>
    )}
  </div>

  <!-- ── Map Dialog ── -->
  {location && (
    <dialog id="mapDialog" class="map-dialog">
      <div class="map-dialog-inner">
        <div class="map-dialog-header">
          <div>
            <h3 class="map-dialog-title">📍 Ubicación del Reporte</h3>
            <p class="map-dialog-sub mono">{location.direccionCompleta}</p>
          </div>
          <button class="map-dialog-close" id="closeMapBtn">✕</button>
        </div>
        <div id="detailMap" class="detail-map-container"></div>
      </div>
    </dialog>
  )}

</MainLayout>

{location && (
  <script is:inline
    data-lat={location.latitud}
    data-lng={location.longitud}
    data-dir={location.direccionCompleta}
    data-mun={location.municipio}
    id="mapInitScript">
    (function() {
      const s = document.getElementById('mapInitScript');
      const lat = parseFloat(s.dataset.lat);
      const lng = parseFloat(s.dataset.lng);
      const dir = s.dataset.dir;
      const mun = s.dataset.mun;

      const dialog  = document.getElementById('mapDialog');
      const openBtn = document.getElementById('openMapBtn');
      const closeBtn = document.getElementById('closeMapBtn');

      if (!dialog || !openBtn) return;

      let mapInitialized = false;
      let leafletMap = null;

      openBtn.addEventListener('click', () => {
        dialog.showModal();
        if (!mapInitialized && typeof L !== 'undefined') {
          leafletMap = L.map('detailMap').setView([lat, lng], 15);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
          }).addTo(leafletMap);
          L.marker([lat, lng])
            .addTo(leafletMap)
            .bindPopup(`<b>${mun}</b><br><small>${dir}</small>`)
            .openPopup();
          mapInitialized = true;
          // Fix Leaflet tile rendering inside dialog
          setTimeout(() => leafletMap.invalidateSize(), 100);
        }
      });

      closeBtn.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
    })();
  </script>
)}

<style>
.page-breadcrumb { margin-bottom: 1.5rem; font-size: 0.85rem; }
.page-breadcrumb a { color: var(--text-muted); }
.page-breadcrumb a:hover { color: var(--accent); }

.alert-error {
  background: var(--danger-dim); border: 1px solid rgba(239,68,68,0.3);
  border-radius: var(--radius-lg); padding: 1rem 1.25rem; color: var(--danger);
}

.detail-wrap { display: flex; flex-direction: column; gap: 2rem; }
.detail-header { display: flex; flex-direction: column; gap: 0.75rem; }
.detail-meta-top { display: flex; align-items: center; gap: 1rem; }
.detail-id { font-size: 0.75rem; color: var(--text-muted); letter-spacing: 0.1em; }
.detail-title { font-size: clamp(1.6rem, 4vw, 2.75rem); line-height: 1.15; max-width: 800px; }
.detail-meta-row { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: center; }
.meta-item { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; color: var(--text-muted); }

.btn-map {
  display: inline-flex; align-items: center; gap: 0.35rem;
  background: var(--surface-2); border: 1px solid var(--border);
  color: var(--text-dim); font-family: var(--font-display);
  font-size: 0.8rem; font-weight: 600; padding: 0.35rem 0.8rem;
  border-radius: var(--radius); cursor: pointer; transition: all var(--transition);
}
.btn-map:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

.detail-body {
  display: grid; grid-template-columns: 1fr 380px; gap: 2.5rem; align-items: start;
}
@media (max-width: 900px) { .detail-body { grid-template-columns: 1fr; } }

.info-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1rem;
}
.info-card-label { font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.6rem; }
.obs-card { border-left: 3px solid var(--accent); }
.obs-text { margin: 0; color: var(--text-dim); font-style: italic; font-size: 0.9rem; line-height: 1.7; }
.data-list { display: flex; flex-direction: column; gap: 0.5rem; }
.data-row { display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; }
.data-row dt { font-size: 0.8rem; color: var(--text-muted); white-space: nowrap; }
.data-row dd { font-size: 0.78rem; color: var(--text-dim); margin: 0; text-align: right; overflow: hidden; text-overflow: ellipsis; }
.status-row { display: flex; align-items: center; gap: 0.75rem; }
.btn-back { display: inline-flex; align-items: center; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color var(--transition); margin-top: 0.5rem; }
.btn-back:hover { color: var(--accent); }

/* ── Map Dialog ── */
.map-dialog {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 0; color: var(--text);
  max-width: min(860px, 95vw); width: 100%; outline: none;
  box-shadow: var(--shadow);
}
.map-dialog::backdrop { background: rgba(0,0,0,0.75); backdrop-filter: blur(6px); }
.map-dialog-inner { display: flex; flex-direction: column; }
.map-dialog-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); gap: 1rem;
}
.map-dialog-title { font-size: 1.1rem; margin-bottom: 0.2rem; }
.map-dialog-sub { font-size: 0.75rem; color: var(--text-muted); }
.map-dialog-close {
  background: none; border: none; color: var(--text-muted); cursor: pointer;
  font-size: 1rem; padding: 0.25rem 0.5rem; border-radius: 4px; transition: all var(--transition); flex-shrink: 0;
}
.map-dialog-close:hover { background: var(--surface-2); color: var(--text); }
.detail-map-container { height: 460px; border-radius: 0 0 var(--radius-lg) var(--radius-lg); overflow: hidden; }
</style>
