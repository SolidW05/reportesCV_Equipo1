---
import MainLayout from '../layouts/MainLayout.astro';
import { decodeJwt, isTokenExpired, JWT_COOKIE, COOKIE_OPTIONS, isAutoridad } from '../utils/auth';
import { registerUser } from '../services/authService';

// Already authenticated? Redirect
const existingToken = Astro.cookies.get(JWT_COOKIE)?.value;
if (existingToken) {
  const p = decodeJwt(existingToken);
  if (p && !isTokenExpired(p)) {
    return Astro.redirect(isAutoridad(p.tipoUser) ? '/admin/reports' : '/reports');
  }
}

let error: string | null = null;
let success = false;
let nameValue = '';
let emailValue = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  nameValue  = data.get('name')?.toString()  ?? '';
  emailValue = data.get('email')?.toString() ?? '';
  const password = data.get('password')?.toString() ?? '';
  const confirm  = data.get('confirm')?.toString()  ?? '';

  if (password !== confirm) {
    error = 'Las contraseñas no coinciden.';
  } else {
    try {
      await registerUser(nameValue, emailValue, password);
      return Astro.redirect('/login?registered=1');
    } catch (e) {
      error = (e as Error).message;
    }
  }
}

// Show success toast if redirected from successful registration
const registered = new URL(Astro.request.url).searchParams.get('registered');
---

<MainLayout title="Registrarse" description="Crea tu cuenta en ReporTA">
  <div class="container auth-page">
    <div class="auth-card animate-fade-up">

      <div class="auth-brand">
        <span class="logo-mark">▣</span>
        <span class="logo-text">ReporTA</span>
      </div>

      <h1 class="auth-title">Crear Cuenta</h1>
      <p class="auth-sub">Regístrate para reportar problemas en tu municipio.</p>

      {error && (
        <div class="auth-alert" role="alert">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          {error}
        </div>
      )}

      <form method="POST" class="auth-form" id="regForm" novalidate>
        <div class="field">
          <label for="name" class="field-label">Nombre completo</label>
          <input id="name" name="name" type="text" required autocomplete="name"
                 value={nameValue} class="field-input" placeholder="Juan Pérez" />
        </div>
        <div class="field">
          <label for="email" class="field-label">Correo electrónico</label>
          <input id="email" name="email" type="email" required autocomplete="email"
                 value={emailValue} class="field-input" placeholder="tu@correo.mx" />
        </div>
        <div class="field">
          <label for="password" class="field-label">Contraseña</label>
          <input id="password" name="password" type="password" required
                 autocomplete="new-password" class="field-input" placeholder="Mínimo 6 caracteres" />
        </div>
        <div class="field">
          <label for="confirm" class="field-label">Confirmar contraseña</label>
          <input id="confirm" name="confirm" type="password" required
                 autocomplete="new-password" class="field-input" placeholder="Repite tu contraseña" />
        </div>

        <button type="submit" class="auth-btn" id="regBtn">
          <span id="btnLabel">Crear cuenta</span>
          <span id="btnSpinner" class="spinner" style="display:none" aria-hidden="true"></span>
        </button>
      </form>

      <p class="auth-footer">
        ¿Ya tienes cuenta? <a href="/login">Inicia sesión →</a>
      </p>
    </div>
  </div>
</MainLayout>

<style>
.auth-page {
  min-height: calc(100vh - 64px - 73px);
  display: flex; align-items: center; justify-content: center;
  padding: 3rem 1.5rem;
}
.auth-card {
  width: 100%; max-width: 440px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 2.5rem;
}
.auth-brand { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; }
.auth-title { font-size: 1.75rem; margin-bottom: 0.4rem; }
.auth-sub { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.75rem; line-height: 1.6; }

.auth-alert {
  display: flex; align-items: center; gap: 0.5rem;
  background: var(--danger-dim); color: var(--danger);
  border: 1px solid rgba(239,68,68,0.3); border-radius: var(--radius);
  padding: 0.7rem 1rem; font-size: 0.85rem; margin-bottom: 1.25rem;
}

.auth-form { display: flex; flex-direction: column; gap: 1.1rem; }
.field { display: flex; flex-direction: column; gap: 0.4rem; }
.field-label {
  font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
  color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.07em;
}
.field-input {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: var(--radius); color: var(--text);
  font-family: var(--font-display); font-size: 0.9375rem;
  padding: 0.65rem 0.875rem; width: 100%; outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.field-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(245,158,11,0.15); }

.auth-btn {
  display: flex; align-items: center; justify-content: center; gap: 0.6rem;
  background: var(--accent); color: var(--bg);
  font-family: var(--font-display); font-weight: 800; font-size: 1rem;
  padding: 0.75rem; border: none; border-radius: var(--radius);
  cursor: pointer; width: 100%; margin-top: 0.25rem;
  transition: background var(--transition), transform var(--transition);
}
.auth-btn:hover { background: var(--accent-hover); transform: translateY(-2px); }
.auth-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.spinner {
  width: 16px; height: 16px; border: 2px solid var(--bg);
  border-top-color: transparent; border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
.auth-footer { text-align: center; margin-top: 1.5rem; font-size: 0.875rem; color: var(--text-muted); }
.auth-footer a { color: var(--accent); font-weight: 600; }
</style>

<script>
const form  = document.getElementById('regForm')    as HTMLFormElement;
const btn   = document.getElementById('regBtn')     as HTMLButtonElement;
const label = document.getElementById('btnLabel')!;
const spin  = document.getElementById('btnSpinner')!;
form.addEventListener('submit', () => {
  btn.disabled = true;
  label.textContent = 'Creando cuenta...';
  spin.style.display = 'inline-block';
});
</script>
